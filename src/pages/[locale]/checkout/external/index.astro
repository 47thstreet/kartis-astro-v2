---
import Base from '../../../../layouts/Base.astro';
import ExternalCheckoutForm from '../../../../components/checkout/ExternalCheckoutForm';

const { locale } = Astro.params;
const url = new URL(Astro.request.url);

const name      = url.searchParams.get('name')     ?? 'Event Ticket';
const price     = parseInt(url.searchParams.get('price') ?? '0', 10);
const currency  = url.searchParams.get('currency') ?? 'USD';
const ref       = url.searchParams.get('ref')      ?? '';
const canceled  = url.searchParams.has('canceled');
const date      = url.searchParams.get('date')     ?? '';
const location  = url.searchParams.get('location') ?? '';
const desc      = url.searchParams.get('desc')     ?? '';
const image     = url.searchParams.get('image')    ?? '';

function formatMoney(cents: number, cur: string) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: cur.toUpperCase(), minimumFractionDigits: 0 }).format(cents / 100);
}
const isFree = price === 0;
const fmtPrice = isFree ? 'Free' : formatMoney(price, currency);
---
<Base title={`${name} — KARTIS`}>

  <div class="min-h-screen bg-[#05050a] text-white overflow-x-hidden">

    <!-- Fixed background blobs — anchored, won't cause scroll -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="absolute top-[-15%] left-[30%] w-[700px] h-[500px] rounded-full blur-[140px]"
        style="background: radial-gradient(circle, rgba(124,58,237,0.14), transparent 70%)" />
      <div class="absolute bottom-[-10%] right-[10%] w-[500px] h-[400px] rounded-full blur-[120px]"
        style="background: radial-gradient(circle, rgba(99,102,241,0.08), transparent 70%)" />
    </div>

    <!-- Nav -->
    <nav class="sticky top-0 z-40 flex items-center justify-between px-6 py-4 border-b border-white/[0.04] backdrop-blur-xl"
      style="background: rgba(5,5,10,0.75)">
      <a href={`/${locale}`} class="flex items-center gap-2.5 group">
        <div class="w-7 h-7 rounded-lg bg-violet-500/20 ring-1 ring-violet-500/30 flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <span class="text-[13px] font-black tracking-[0.18em] uppercase text-white/70 group-hover:text-white/90 transition-colors">KARTIS</span>
      </a>
      <div class="flex items-center gap-1.5 text-[11px] text-white/25">
        <svg class="w-3 h-3 text-emerald-400/70" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="8"/></svg>
        {isFree ? 'Secured by KARTIS' : 'Secured by Stripe'}
      </div>
    </nav>

    <!-- Page body -->
    <div class="relative z-10 w-full max-w-2xl mx-auto px-4 py-8 md:py-12 space-y-5">

      <!-- ① Hero card -->
      <div class="relative rounded-3xl overflow-hidden"
        style="background: rgba(255,255,255,0.02); box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 24px 64px rgba(0,0,0,0.4)">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet-400/50 to-transparent" />

        {image ? (
          <div class="relative h-72 sm:h-80 overflow-hidden">
            <img src={image} alt={name} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(5,5,10,1) 0%, rgba(5,5,10,0.6) 35%, rgba(5,5,10,0.15) 70%, transparent 100%)" />
            <div class="absolute top-4 left-5 z-10">
              <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest"
                style={isFree
                  ? "background: rgba(16,185,129,0.3); color: rgba(110,231,183,1); box-shadow: inset 0 0 0 1px rgba(16,185,129,0.4); backdrop-filter: blur(12px)"
                  : "background: rgba(124,58,237,0.3); color: rgba(167,139,250,1); box-shadow: inset 0 0 0 1px rgba(124,58,237,0.4); backdrop-filter: blur(12px)"}>
                {isFree ? 'Free RSVP' : 'Live Event'}
              </span>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-5 z-10">
              <h1 class="text-2xl sm:text-3xl font-black text-white leading-tight tracking-tight drop-shadow-xl">{name}</h1>
            </div>
          </div>
        ) : (
          <div class="relative h-48 overflow-hidden"
            style="background: linear-gradient(135deg, rgba(124,58,237,0.25) 0%, rgba(99,102,241,0.12) 60%, rgba(5,5,10,0.9) 100%)">
            <div class="absolute -top-8 -left-8 w-56 h-56 rounded-full blur-3xl opacity-60"
              style="background: radial-gradient(circle, rgba(124,58,237,0.6), transparent 70%)" />
            <div class="absolute top-4 left-5 z-10">
              <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest"
                style={isFree
                  ? "background: rgba(16,185,129,0.3); color: rgba(110,231,183,1); box-shadow: inset 0 0 0 1px rgba(16,185,129,0.4)"
                  : "background: rgba(124,58,237,0.3); color: rgba(167,139,250,1); box-shadow: inset 0 0 0 1px rgba(124,58,237,0.4)"}>
                {isFree ? 'Free RSVP' : 'Live Event'}
              </span>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-5 z-10">
              <h1 class="text-2xl sm:text-3xl font-black text-white leading-tight tracking-tight drop-shadow-xl">{name}</h1>
            </div>
          </div>
        )}
      </div>

      <!-- ② Event metadata -->
      <div class="grid grid-cols-2 gap-3">
        <div class="flex items-start gap-3 rounded-2xl p-4" style="background: rgba(255,255,255,0.02); box-shadow: 0 0 0 1px rgba(255,255,255,0.05)">
          <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0" style="background: rgba(124,58,237,0.15)">
            {date ? (
              <svg class="w-4 h-4 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            ) : (
              <svg class="w-4 h-4 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            )}
          </div>
          <div class="min-w-0 overflow-hidden">
            <p class="text-[10px] font-bold uppercase tracking-widest text-white/25 mb-0.5">{date ? 'Date & Time' : 'Instant'}</p>
            <p class="text-[13px] font-semibold text-white/75 leading-snug break-words">{date || 'QR ticket by email'}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-2xl p-4" style="background: rgba(255,255,255,0.02); box-shadow: 0 0 0 1px rgba(255,255,255,0.05)">
          <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0" style="background: rgba(124,58,237,0.15)">
            {location ? (
              <svg class="w-4 h-4 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            ) : (
              <svg class="w-4 h-4 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            )}
          </div>
          <div class="min-w-0 overflow-hidden">
            <p class="text-[10px] font-bold uppercase tracking-widest text-white/25 mb-0.5">{location ? 'Location' : 'Secure'}</p>
            <p class="text-[13px] font-semibold text-white/75 leading-snug break-words">{location || '256-bit encryption'}</p>
          </div>
        </div>
      </div>

      <!-- ③ Description -->
      {desc && (
        <div class="rounded-2xl px-5 py-4" style="background: rgba(255,255,255,0.02); box-shadow: 0 0 0 1px rgba(255,255,255,0.05)">
          <p class="text-[10px] font-bold uppercase tracking-widest text-white/20 mb-2">About this event</p>
          <p class="text-[13px] text-white/45 leading-relaxed break-words">{desc}</p>
        </div>
      )}

      <!-- ④ What's included -->
      <div class="rounded-2xl px-5 py-4 space-y-3" style="background: rgba(255,255,255,0.02); box-shadow: 0 0 0 1px rgba(255,255,255,0.05)">
        <p class="text-[10px] font-bold uppercase tracking-widest text-white/20">What's included</p>
        {[
          "Unique QR ticket delivered to your email",
          "Entry pass valid at the door — no app needed",
          "Instant order confirmation from KARTIS",
          "Covered by our buyer guarantee",
        ].map(item => (
          <div class="flex items-center gap-3 text-[13px] text-white/45">
            <svg class="w-3.5 h-3.5 text-emerald-400/80 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{item}</span>
          </div>
        ))}
      </div>

      <!-- ⑤ Checkout card -->
      <div class="relative rounded-3xl overflow-hidden"
        style="background: rgba(255,255,255,0.02); box-shadow: 0 0 0 1px rgba(255,255,255,0.07), 0 32px 80px rgba(0,0,0,0.4)">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet-400/50 to-transparent" />

        <!-- Price header -->
        <div class="flex items-end justify-between gap-4 px-6 pt-6 pb-5 border-b border-white/[0.05]">
          <div class="min-w-0 overflow-hidden">
            <p class="text-[10px] font-bold uppercase tracking-widest text-white/25 mb-1">{isFree ? 'Your RSVP' : 'Your ticket'}</p>
            <p class="text-[13px] text-white/40 leading-snug truncate">1 × {name}</p>
          </div>
          <p class="text-3xl font-black text-white leading-none shrink-0">{fmtPrice}</p>
        </div>

        <!-- Form -->
        <div class="px-6 py-6">
          {canceled && (
            <div class="mb-5 rounded-xl px-4 py-3 text-[12px] text-amber-400/90 ring-1 ring-amber-500/20"
              style="background: rgba(245,158,11,0.07)">
              Payment was canceled — you can try again below.
            </div>
          )}
          <ExternalCheckoutForm
            eventName={name}
            priceCents={price}
            currency={currency}
            supplierRef={ref}
            client:load
          />
        </div>
      </div>

      <!-- Footer note -->
      <div class="flex items-center justify-between px-1 pb-4">
        <div class="flex items-center gap-4 flex-wrap">
          {(isFree ? ["KARTIS", "Secure"] : ["PCI-DSS", "SSL", "Stripe"]).map(label => (
            <span class="flex items-center gap-1.5 text-[11px] text-white/20">
              <svg class="w-3 h-3 text-white/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              {label}
            </span>
          ))}
        </div>
        <p class="text-[11px] text-white/20">
          <a href={`/${locale}/contact`} class="hover:text-white/40 transition-colors underline underline-offset-2">Need help?</a>
        </p>
      </div>

    </div>
  </div>
</Base>
