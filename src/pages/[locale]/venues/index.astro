---
import PageShell from '../../../layouts/PageShell.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { prisma } from '../../../lib/prisma';

const { locale } = Astro.params;
const venues = await prisma.venue.findMany({ include: { events: true }, orderBy: { name: 'asc' } });
---
<PageShell locale={locale} title="Venues — KARTIS">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-10 space-y-3">
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/25">Locations</p>
      <h1 class="text-4xl font-black tracking-tight text-white">Venues</h1>
    </div>

    {venues.length === 0 ? (
      <EmptyState
        icon='<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>'
        iconColor="rgba(244,114,182,0.7)"
        title="No venues yet"
        description="Venues will appear here as organizers add locations for their events."
      />
    ) : (
      <div class="grid gap-3 sm:grid-cols-2">
        {venues.map((venue: any) => (
          <div class="rounded-2xl p-5 space-y-3" style="background: rgba(255,255,255,0.02); box-shadow: 0 0 0 1px rgba(255,255,255,0.05)">
            <p class="font-bold text-white/85">{venue.name}</p>
            <div class="space-y-1.5 text-[12px] text-white/30">
              <p>{venue.city} · {venue.address}</p>
              <p>{venue.events.length} event{venue.events.length !== 1 ? 's' : ''}</p>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</PageShell>
