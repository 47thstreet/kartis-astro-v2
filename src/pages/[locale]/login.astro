---
import Base from '@/layouts/Base.astro';
import LoginForm from '@/components/LoginForm';

const { locale } = Astro.params;
const callbackUrl = Astro.url.searchParams.get('callbackUrl') || `/${locale}/app`;
---

<Base title="Sign In — Kartis">
  <div class="min-h-screen bg-[#05050a] flex items-center justify-center px-4">
    <!-- Background orbs -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-violet-600/10 blur-[120px]"></div>
    </div>

    <div class="relative w-full max-w-sm">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href={`/${locale}`} class="inline-flex items-center gap-2 group">
          <div class="w-9 h-9 rounded-xl bg-violet-600 flex items-center justify-center shadow-lg shadow-violet-600/30 group-hover:shadow-violet-600/50 transition-shadow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12C2 6.48 6.48 2 12 2s10 4.48 10 10-4.48 10-10 10S2 17.52 2 12z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <span class="text-xl font-bold text-white tracking-tight">Kartis</span>
        </a>
        <p class="mt-3 text-sm text-white/50">Sign in to your account</p>
      </div>

      <!-- Card -->
      <div class="bg-white/[0.04] border border-white/[0.08] rounded-2xl p-8 backdrop-blur-sm shadow-2xl">
        <LoginForm callbackUrl={callbackUrl} client:load />
      </div>

      <!-- Footer links -->
      <p class="mt-6 text-center text-xs text-white/30">
        Don't have an account?{' '}
        <a href={`/${locale}/register`} class="text-violet-400 hover:text-violet-300 transition-colors">
          Create one
        </a>
      </p>
    </div>
  </div>
</Base>
