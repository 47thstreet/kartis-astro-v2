---
import AppShell from '../../../../../../layouts/AppShell.astro';
import { getSession } from 'auth-astro/server';
import { prisma } from '../../../../../../lib/prisma';
import EventReport from '../../../../../../components/reports/EventReport';

const { locale, id } = Astro.params;
const session = await getSession(Astro.request);
if (!session?.user) return Astro.redirect(`/${locale}/login`);

const email = session.user.email ?? 'guest';
const role = (session.user as any).role ?? 'GUEST';

if (!['ORGANIZER', 'SUPER_ADMIN'].includes(role)) {
  return Astro.redirect(`/${locale}/app`);
}

const event = await prisma.event.findUnique({
  where: { id },
  select: { id: true, name: true },
});
---
<AppShell locale={locale!} email={email} role={role} title={`Report — ${event?.name ?? 'Event'}`}>
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="mb-8">
      <a href={`/${locale}/app/organizer/events`}
        class="inline-flex items-center gap-1.5 text-[12px] text-white/30 hover:text-white/60 transition-colors mb-3">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Events
      </a>
      <h1 class="text-2xl font-black text-white">{event?.name ?? 'Event'}</h1>
      <p class="text-sm text-white/30 mt-1">Sales & performance report</p>
    </div>

    {event ? (
      <EventReport client:load eventId={event.id} />
    ) : (
      <div class="rounded-2xl p-8 text-center" style="background:rgba(255,255,255,0.02);box-shadow:0 0 0 1px rgba(255,255,255,0.05)">
        <p class="text-white/30 text-sm">Event not found.</p>
      </div>
    )}
  </div>
</AppShell>
