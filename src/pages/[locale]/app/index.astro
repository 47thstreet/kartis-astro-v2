---
import AppShell from '../../../layouts/AppShell.astro';
import { getSession } from 'auth-astro/server';

const { locale } = Astro.params;
const session = await getSession(Astro.request);
if (!session?.user) return Astro.redirect(`/${locale}`);

const email = session.user.email ?? 'guest';

const tiles = [
  { href: `/${locale}/cms`,                  label: "CMS",             sub: "Manage events for partner sites" },
  { href: `/${locale}/app/promoter`,         label: "Promoter",       sub: "Links, clicks & pending commissions" },
  { href: `/${locale}/app/staff/checkin`,    label: "Staff Check-In",  sub: "Validate attendee QR codes at the door" },
  { href: `/${locale}/app/organizer/events`, label: "Organizer",       sub: "Live ops, reports and venue map editor", wide: true },
  { href: `/${locale}/app/activity`,         label: "Activity",        sub: "Audit log of all actions across your account" },
  { href: `/${locale}/app/settings`,         label: "Settings",        sub: "Profile, password & preferences" },
];
---
<AppShell locale={locale} email={email} role={(session.user as any).role ?? 'GUEST'}>
  <div class="max-w-3xl mx-auto px-6 py-12">
    <div class="mb-10 space-y-1">
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/20">Dashboard</p>
      <h1 class="text-3xl font-black text-white">Welcome back</h1>
      <p class="text-sm text-white/30">{email}</p>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {tiles.map(({ href, label, sub, wide }) => (
        <a href={href}
          class={`group relative rounded-2xl p-5 flex items-center justify-between transition-all duration-200 hover:bg-white/[0.03] ${wide ? 'sm:col-span-2' : ''}`}
          style="background: rgba(255,255,255,0.02); box-shadow: 0 0 0 1px rgba(255,255,255,0.05)">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-white/[0.04] ring-1 ring-white/8 flex items-center justify-center group-hover:bg-violet-500/10 group-hover:ring-violet-500/25 transition-all duration-200">
              <svg class="w-4 h-4 text-white/30 group-hover:text-violet-400 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-white/75 group-hover:text-white transition-colors">{label}</p>
              <p class="text-[12px] text-white/25">{sub}</p>
            </div>
          </div>
          <svg class="w-4 h-4 text-white/10 group-hover:text-white/35 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      ))}
    </div>
  </div>
</AppShell>
