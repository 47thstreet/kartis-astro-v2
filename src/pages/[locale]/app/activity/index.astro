---
import AppShell from '../../../../layouts/AppShell.astro';
import { getSession } from 'auth-astro/server';
import ActivityFeed from '../../../../components/reports/ActivityFeed';

const { locale } = Astro.params;
const session = await getSession(Astro.request);
if (!session?.user) return Astro.redirect(`/${locale}/login`);

const email = session.user.email ?? '';
const role = (session.user as any).role ?? 'GUEST';

if (!['ORGANIZER', 'SUPER_ADMIN'].includes(role)) {
  return Astro.redirect(`/${locale}/app`);
}
---
<AppShell locale={locale} email={email} role={role} title="Activity — KARTIS">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <div class="mb-8 space-y-1">
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/20">System</p>
      <h1 class="text-3xl font-black text-white">Activity</h1>
      <p class="text-sm text-white/30">Recent actions across your account</p>
    </div>
    <ActivityFeed client:load />
  </div>
</AppShell>
