---
import Base from '@/layouts/Base.astro';

const { locale } = Astro.params;
---

<Base title="Create Account — Kartis">
  <div class="min-h-screen bg-[#05050a] flex items-center justify-center px-4">
    <!-- Background orbs -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-violet-600/10 blur-[120px]"></div>
    </div>

    <div class="relative w-full max-w-sm">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href={`/${locale}`} class="inline-flex items-center gap-2 group">
          <div class="w-9 h-9 rounded-xl bg-violet-600 flex items-center justify-center shadow-lg shadow-violet-600/30 group-hover:shadow-violet-600/50 transition-shadow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12C2 6.48 6.48 2 12 2s10 4.48 10 10-4.48 10-10 10S2 17.52 2 12z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <span class="text-xl font-bold text-white tracking-tight">Kartis</span>
        </a>
        <p class="mt-3 text-sm text-white/50">Create your account</p>
      </div>

      <!-- Card -->
      <div class="bg-white/[0.04] border border-white/[0.08] rounded-2xl p-8 backdrop-blur-sm shadow-2xl">
        <form id="register-form" class="space-y-4">
          <!-- Error -->
          <div id="register-error" class="hidden items-start gap-2.5 rounded-xl px-4 py-3 text-[12px] text-red-400 ring-1 ring-red-500/20" style="background: rgba(239,68,68,0.07)">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span id="register-error-text"></span>
          </div>

          <!-- Success -->
          <div id="register-success" class="hidden items-start gap-2.5 rounded-xl px-4 py-3 text-[12px] text-emerald-400 ring-1 ring-emerald-500/20" style="background: rgba(16,185,129,0.07)">
            <span>Account created! Redirecting to login...</span>
          </div>

          <!-- Name -->
          <div class="space-y-1.5">
            <label for="name" class="text-[11px] font-bold uppercase tracking-widest text-white/30">Name</label>
            <div class="relative rounded-xl ring-1 ring-white/[0.06] focus-within:ring-violet-500/50 focus-within:shadow-[0_0_20px_rgba(124,58,237,0.1)] transition-all duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-white/20"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <input
                id="name" name="name" type="text" required autocomplete="name" placeholder="Your name"
                class="w-full bg-transparent py-3 pl-10 pr-4 text-sm text-white/80 placeholder:text-white/20 outline-none rounded-xl"
              />
            </div>
          </div>

          <!-- Email -->
          <div class="space-y-1.5">
            <label for="email" class="text-[11px] font-bold uppercase tracking-widest text-white/30">Email</label>
            <div class="relative rounded-xl ring-1 ring-white/[0.06] focus-within:ring-violet-500/50 focus-within:shadow-[0_0_20px_rgba(124,58,237,0.1)] transition-all duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-white/20"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <input
                id="email" name="email" type="email" required autocomplete="email" placeholder="you@example.com"
                class="w-full bg-transparent py-3 pl-10 pr-4 text-sm text-white/80 placeholder:text-white/20 outline-none rounded-xl"
              />
            </div>
          </div>

          <!-- Password -->
          <div class="space-y-1.5">
            <label for="password" class="text-[11px] font-bold uppercase tracking-widest text-white/30">Password</label>
            <div class="relative rounded-xl ring-1 ring-white/[0.06] focus-within:ring-violet-500/50 focus-within:shadow-[0_0_20px_rgba(124,58,237,0.1)] transition-all duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-white/20"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input
                id="password" name="password" type="password" required autocomplete="new-password" placeholder="Min. 8 characters"
                minlength="8"
                class="w-full bg-transparent py-3 pl-10 pr-4 text-sm text-white/80 placeholder:text-white/20 outline-none rounded-xl"
              />
            </div>
          </div>

          <button
            type="submit" id="register-btn"
            class="group relative w-full overflow-hidden flex items-center justify-center gap-2 py-3.5 rounded-xl text-sm font-bold text-white transition-all duration-200 disabled:opacity-50 mt-2"
            style="background: linear-gradient(135deg, hsl(262 83% 58%), hsl(252 83% 53%))"
          >
            <span class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/10 to-transparent pointer-events-none"></span>
            <span id="btn-text">Create account</span>
            <svg id="btn-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform duration-200"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
          </button>
        </form>
      </div>

      <!-- Footer links -->
      <p class="mt-6 text-center text-xs text-white/30">
        Already have an account?{' '}
        <a href={`/${locale}/login`} class="text-violet-400 hover:text-violet-300 transition-colors">
          Sign in
        </a>
      </p>
    </div>
  </div>
</Base>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorDiv = document.getElementById('register-error')!;
  const errorText = document.getElementById('register-error-text')!;
  const successDiv = document.getElementById('register-success')!;
  const btn = document.getElementById('register-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text')!;
  const btnArrow = document.getElementById('btn-arrow')!;
  const btnSpinner = document.getElementById('btn-spinner')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    errorDiv.classList.remove('flex');
    successDiv.classList.add('hidden');
    btn.disabled = true;
    btnText.textContent = 'Creating account...';
    btnArrow.classList.add('hidden');
    btnSpinner.classList.remove('hidden');

    const name = (form.querySelector('#name') as HTMLInputElement).value;
    const email = (form.querySelector('#email') as HTMLInputElement).value;
    const password = (form.querySelector('#password') as HTMLInputElement).value;

    try {
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, password }),
      });
      const data = await res.json();

      if (res.ok) {
        successDiv.classList.remove('hidden');
        successDiv.classList.add('flex');
        // Get locale from URL path
        const locale = window.location.pathname.split('/')[1] || 'en';
        setTimeout(() => { window.location.href = `/${locale}/login`; }, 1500);
      } else {
        errorDiv.classList.remove('hidden');
        errorDiv.classList.add('flex');
        errorText.textContent = data.error || 'Registration failed.';
        btn.disabled = false;
        btnText.textContent = 'Create account';
        btnArrow.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
      }
    } catch {
      errorDiv.classList.remove('hidden');
      errorDiv.classList.add('flex');
      errorText.textContent = 'Network error. Please try again.';
      btn.disabled = false;
      btnText.textContent = 'Create account';
      btnArrow.classList.remove('hidden');
      btnSpinner.classList.add('hidden');
    }
  });
</script>
