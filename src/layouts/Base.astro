---
import '../styles/globals.css';

interface Props {
  title?: string;
}
const { title = "KARTIS" } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#05050a] text-white antialiased">
    <slot />
  </body>
</html>
