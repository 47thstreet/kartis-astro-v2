---
import Base from './Base.astro';

interface Props {
  locale: string;
  title?: string;
  back?: { href: string; label: string };
}

const { locale, title, back } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { label: "Events",   href: `/${locale}/events`   },
  { label: "Venues",   href: `/${locale}/venues`   },
  { label: "Pricing",  href: `/${locale}/pricing`  },
  { label: "Features", href: `/${locale}/features` },
];
---
<Base title={title}>
  <div class="min-h-screen bg-[#05050a] text-white flex flex-col">

    <!-- Nav -->
    <header class="sticky top-0 z-40 flex items-center justify-between px-6 py-4 border-b border-white/[0.04] backdrop-blur-xl"
      style="background: rgba(5,5,10,0.8)">

      {back ? (
        <a href={back.href} class="flex items-center gap-2 text-[13px] text-white/40 hover:text-white/70 transition-colors duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
          {back.label}
        </a>
      ) : (
        <a href={`/${locale}`} class="flex items-center gap-2.5 group">
          <div class="w-7 h-7 rounded-lg bg-violet-500/20 ring-1 ring-violet-500/30 flex items-center justify-center group-hover:bg-violet-500/30 transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-violet-400"><path d="M3 12l9-9 9 9"/><path d="M9 21V9h6v12"/><rect x="10" y="14" width="4" height="7" rx="0.5"/></svg>
          </div>
          <span class="text-sm font-black tracking-[0.18em] uppercase text-white/80">KARTIS APP</span>
        </a>
      )}

      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(({ label, href }) => {
          const active = pathname.startsWith(href);
          return (
            <a href={href} class={`px-3 py-1.5 rounded-lg text-[13px] font-medium transition-all duration-200 ${active ? 'text-white bg-white/[0.06]' : 'text-white/40 hover:text-white/70 hover:bg-white/[0.03]'}`}>
              {label}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center gap-3">
        <a href={`/${locale}/app`} class="px-4 py-2 rounded-xl text-[13px] font-bold text-white transition-all duration-200"
          style="background: linear-gradient(135deg, hsl(262 83% 58%), hsl(252 83% 53%))">
          Get access
        </a>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/[0.04] px-6 py-8 mt-auto">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-[12px] text-white/20">
        <span class="font-black tracking-[0.15em] uppercase">KARTIS APP</span>
        <nav class="flex items-center gap-5">
          {navLinks.map(({ label, href }) => (
            <a href={href} class="hover:text-white/50 transition-colors duration-200">{label}</a>
          ))}
          <a href={`/${locale}/contact`} class="hover:text-white/50 transition-colors duration-200">Contact</a>
          <a href={`/${locale}/faq`} class="hover:text-white/50 transition-colors duration-200">FAQ</a>
        </nav>
        <span>© {new Date().getFullYear()} Kartis</span>
      </div>
    </footer>
  </div>
</Base>
