---
import Base from './Base.astro';
import { AppShellNav } from '../components/AppShellNav';

interface Props {
  locale: string;
  email: string;
  role: string;
  title?: string;
}
const { locale, email, role, title } = Astro.props;
---
<Base title={title ?? "KARTIS APP"}>
  <div class="min-h-screen bg-[#05050a] text-white flex">
    <AppShellNav locale={locale} email={email} role={role} client:load />
    <div class="flex-1 md:ml-56 pb-24 md:pb-0 min-h-screen">
      <slot />
    </div>
  </div>
</Base>
