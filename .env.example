# ===========================================
# Kartis — Environment Variables
# ===========================================

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://user:password@localhost:5432/kartis?schema=public

# ── Auth (auth-astro / AuthJS) ──
AUTH_SECRET=generate-a-random-secret-here
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3031
NEXTAUTH_SECRET=generate-a-random-secret-here

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Email (SMTP) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Kartis <hello@kartis.app>

# ── Pusher (real-time updates) ──
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# ── Sentry (error tracking) ──
SENTRY_DSN=

# ── Admin CMS ──
ADMIN_SECRET=change-this-secret

# ── Optional ──
DEMO_EMAIL_TO=
