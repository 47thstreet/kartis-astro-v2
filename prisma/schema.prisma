generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  PROMOTER
  ORGANIZER
  STAFF
  SUPER_ADMIN
}

enum TableStatus {
  AVAILABLE
  HELD
  RESERVED
  BLOCKED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderItemType {
  TICKET
  TABLE
  DEPOSIT
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
}

model User {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  passwordHash   String?
  role           UserRole    @default(GUEST)
  promoter       Promoter?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orders         Order[]
  auditLogs      AuditLog[]  @relation("auditActor")
}

model Venue {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  city          String
  address       String
  description   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  events        Event[]
  mapLayouts    VenueMapLayout[]
}

model Event {
  id                      String                 @id @default(cuid())
  venueId                 String
  name                    String
  slug                    String                 @unique
  description             String
  startsAt                DateTime
  endsAt                  DateTime
  isPublished             Boolean                @default(false)
  capacity                Int
  flyerImage              String?
  currency                String                 @default("USD")
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  venue                   Venue                  @relation(fields: [venueId], references: [id])
  ticketTypes             TicketType[]
  tablePackages           TablePackage[]
  orders                  Order[]
  mapLayouts              VenueMapLayout[]
  eventTableConfigs       EventTableConfig[]
  promoterLinks           PromoterLink[]
  commissionRuleProfileId String?
  commissionRuleProfile   CommissionRulesProfile? @relation(fields: [commissionRuleProfileId], references: [id])
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String
  priceCents  Int
  capacity    Int
  soldCount   Int      @default(0)
  saleStart   DateTime
  saleEnd     DateTime
  event       Event    @relation(fields: [eventId], references: [id])
  orderItems  OrderItem[]
}

model TablePackage {
  id                String   @id @default(cuid())
  eventId           String
  venueTableId      String?
  name              String
  capacity          Int
  priceCents        Int
  minimumSpendCents Int
  event             Event      @relation(fields: [eventId], references: [id])
  venueTable        VenueTable? @relation(fields: [venueTableId], references: [id])
  orderItems        OrderItem[]
}

model VenueMapLayout {
  id            String      @id @default(cuid())
  venueId        String
  eventId        String?
  name           String
  mode           String
  floorPlanImage String?
  width          Int         @default(1200)
  height         Int         @default(800)
  draft          Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  venue          Venue       @relation(fields: [venueId], references: [id])
  event          Event?      @relation(fields: [eventId], references: [id])
  zones          VenueZone[]
  tables         VenueTable[]
}

model VenueZone {
  id         String   @id @default(cuid())
  layoutId   String
  name       String
  kind       String
  x          Float
  y          Float
  width      Float
  height     Float
  color      String
  layout     VenueMapLayout @relation(fields: [layoutId], references: [id])
  tables     VenueTable[]
}

model VenueTable {
  id                String      @id @default(cuid())
  layoutId          String
  zoneId            String?
  number            String
  tableType         String
  capacity          Int
  priceCents        Int
  minimumSpendCents Int
  status            TableStatus @default(AVAILABLE)
  x                 Float
  y                 Float
  holdUntil         DateTime?
  heldByOrderId     String?
  layout            VenueMapLayout @relation(fields: [layoutId], references: [id])
  zone              VenueZone?     @relation(fields: [zoneId], references: [id])
  tablePackages     TablePackage[]
  eventTableConfigs EventTableConfig[]
}

model EventTableConfig {
  id           String      @id @default(cuid())
  eventId      String
  venueTableId String
  overridePriceCents Int?
  overrideMinSpendCents Int?
  status       TableStatus @default(AVAILABLE)
  event        Event       @relation(fields: [eventId], references: [id])
  venueTable   VenueTable  @relation(fields: [venueTableId], references: [id])
}

model Order {
  id                  String      @id @default(cuid())
  eventId              String
  userId               String?
  email                String
  status               OrderStatus @default(PENDING)
  subtotalCents        Int
  feesCents            Int
  taxCents             Int
  totalCents           Int
  stripeSessionId      String?    @unique
  stripePaymentIntentId String?
  promoterLinkId       String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  event                Event      @relation(fields: [eventId], references: [id])
  user                 User?      @relation(fields: [userId], references: [id])
  items                OrderItem[]
  passes               GuestPass[]
  promoterLink         PromoterLink? @relation(fields: [promoterLinkId], references: [id])
}

model OrderItem {
  id             String       @id @default(cuid())
  orderId        String
  type           OrderItemType
  ticketTypeId   String?
  tablePackageId String?
  quantity       Int
  unitPriceCents Int
  totalCents     Int
  attendeeName   String?
  attendeeEmail  String?
  order          Order        @relation(fields: [orderId], references: [id])
  ticketType     TicketType?  @relation(fields: [ticketTypeId], references: [id])
  tablePackage   TablePackage? @relation(fields: [tablePackageId], references: [id])
}

model GuestPass {
  id            String   @id @default(cuid())
  orderId       String
  qrToken       String   @unique
  usedAt        DateTime?
  attendeeName  String
  attendeeEmail String
  order         Order    @relation(fields: [orderId], references: [id])
}

model Promoter {
  id            String         @id @default(cuid())
  userId        String         @unique
  displayName   String
  payoutMethod  String?
  user          User           @relation(fields: [userId], references: [id])
  links         PromoterLink[]
  ledgers       CommissionLedger[]
  site          PromoterSite?
}

model PromoterSite {
  id            String   @id @default(cuid())
  promoterId    String   @unique
  slug          String   @unique
  tagline       String   @default("")
  bio           String   @default("")
  primaryColor  String   @default("#8b5cf6")
  accentColor   String   @default("#ec4899")
  heroImage     String?
  logoImage     String?
  socialLinks   Json     @default("{}")
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  promoter      Promoter @relation(fields: [promoterId], references: [id])
}

model PromoterLink {
  id            String   @id @default(cuid())
  eventId       String
  promoterId    String
  code          String   @unique
  ticketTypeId  String?
  clicks        Int      @default(0)
  conversions   Int      @default(0)
  revenueCents  Int      @default(0)
  createdAt     DateTime @default(now())
  event         Event    @relation(fields: [eventId], references: [id])
  promoter      Promoter @relation(fields: [promoterId], references: [id])
  orders        Order[]
}

model CommissionRulesProfile {
  id          String   @id @default(cuid())
  name        String
  rulesJson   Json
  createdAt   DateTime @default(now())
  events      Event[]
}

model CommissionLedger {
  id            String      @id @default(cuid())
  promoterId    String
  orderId       String
  amountCents   Int
  status        PayoutStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  promoter      Promoter     @relation(fields: [promoterId], references: [id])
}

model NotificationTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  subject     String
  bodyHtml    String
  bodyText    String
  locale      String   @default("en")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  payloadJson Json
  createdAt   DateTime @default(now())
  actor       User?    @relation("auditActor", fields: [actorUserId], references: [id])
}

model CmsEvent {
  id             String   @id @default(cuid())
  name           String
  date           String
  time           String   @default("")
  venue          String   @default("")
  location       String   @default("")
  description    String   @default("")
  image          String   @default("")
  imageUrl       String?
  source         String   @default("vibe")
  ticketUrl      String?
  priceCents     Int      @default(0)
  featured       Boolean  @default(false)
  partners       String[] @default([])
  price          String?
  ageRestriction String?
  dressCode      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
